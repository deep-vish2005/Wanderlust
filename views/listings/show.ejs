<% layout("/layouts/boilerplate") %>
<body>
  <div class="row col-8 offset-2 mt-3">
    <h3><%= listingindetail.title %></h3>
    <div class="card shadow-sm border-0 rounded-4">
      <% if(listingindetail.image && listingindetail.image.length > 0){ %>
      <div id="listingCarousel" class="carousel slide">
  <div class="carousel-inner">

    <% listingindetail.image.forEach((img, index) => { %>
      <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
        <img 
          src="<%= img.url %>" 
          class="d-block w-100"
          style="height:400px; object-fit:cover; border-radius:12px;"/>
      </div>
    <% }) %>

  </div>

  <button class="carousel-control-prev" type="button" data-bs-target="#listingCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#listingCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>
</div>
<% } %>
      <div class="card-body">
        <p class="card-text mt-2">
          <span class="fw-semibold fs-5 d-block">
            <%= listingindetail.title %>
          </span>

          <span class="text-muted d-block">
            <%= listingindetail.description %>
          </span>

          <span class="fw-bold text-dark d-block mt-1">
            ₹<%= listingindetail.price.toLocaleString("en-IN") %>
          </span>

          <span class="text-secondary d-block">
            📍 <%= listingindetail.location %>
          </span>

          <span class="text-secondary d-block">
            🌍 <%= listingindetail.country %>
          </span>

          <span class="text-secondary d-block">
  👤 <%= listingindetail.owner.username %>
</span>
        </p>
      </div>
    </div>
  </div>

<% if(currUser && currUser._id.equals(listingindetail.owner._id)) { %>
  <div class="btns d-flex gap-3 offset-2 mt-3">
    <a
      href="/listings/<%= listingindetail._id %>/edit"
      class="btn btn-dark edit"
      >Edit</a
    >

    <form
      method="post"
      action="/listings/<%=listingindetail._id%>?_method=DELETE"
    >
      <button class="btn btn-dark">Delete</button>
    </form>
    <% } %>
  </div>
  <hr />
  
    <div class="row col-8 offset-2 mb-3">
      <% if(currUser) { %>
    <h4>Leave a Review</h4>
    <form
      action="/listings/<%=listingindetail._id%>/reviews"
      method="post"
      novalidate
      class="needs-validation"
    >
      <div class="mb-4">
  <label class="form-label fw-semibold">Rating</label>
  <div class="star-rating">
    <input type="radio" name="review[rating]" value="5" id="star5"><label for="star5">★</label>
    <input type="radio" name="review[rating]" value="4" id="star4"><label for="star4">★</label>
    <input type="radio" name="review[rating]" value="3" id="star3"><label for="star3">★</label>
    <input type="radio" name="review[rating]" value="2" id="star2"><label for="star2">★</label>
    <input type="radio" name="review[rating]" value="1" id="star1"><label for="star1">★</label>
  </div>
</div>
      <div class="mb-3 mt-3">
        <label for="comment" class="form-label">Comments</label>
        <textarea
          name="review[comment]"
          id="comment"
          cols="30"
          rows="5"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">Review cannot be empty !</div>
      </div>
      <button class="btn btn-outline-dark">submit</button>
    </form>
  <% } %>
    

   <h4 class="mt-4 mb-3">All Reviews</h4>

<div class="row">
  <% for (let review of listingindetail.reviews) { %>

    <div class="col-md-6 col-lg-4 mb-4">
      <div class="review-card p-3 h-100">

        <!-- 👤 Fake User -->
        <div class="d-flex align-items-center mb-2">
          <div class="avatar">0</div>
          <span class="ms-2 fw-semibold"><%=review.author.username%></span>
        </div>

        <!-- ⭐ Rating -->
        <div class="text-warning mb-2">
          <% for(let i = 0; i < review.rating; i++) { %>
            ⭐
          <% } %>
        </div>

        <!-- 💬 Comment -->
        <p class="review-text">
          <%= review.comment %>
        </p>
        <form method="post" action="/listings/<%=listingindetail._id%>/reviews/<%=review._id%>?_method=DELETE">
          <button class="btn btn-sm btn-dark">Delete</button>
        </form>

      </div>
    </div>

  <% } %>
</div>
<div id="map" style="height:400px; border-radius:12px;"></div>
</div>
  </div>
 <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script>
  const mapDiv = document.getElementById("map");
  const geometry = <%- JSON.stringify(listingindetail.geometry) %>;

  if (!geometry || !geometry.coordinates || geometry.coordinates.length < 2) {
    mapDiv.innerHTML = "No location data available";
  } else {
    const lat = geometry.coordinates[1];
    const lng = geometry.coordinates[0];

    const map = L.map("map").setView([lat, lng], 10);

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: "&copy; OpenStreetMap"
    }).addTo(map);

    L.marker([lat, lng]).addTo(map)
      .bindPopup("<%= listingindetail.title %>")
      .openPopup();
  }
</script>
</body>

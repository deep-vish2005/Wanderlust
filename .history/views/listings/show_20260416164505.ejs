<% layout("/layouts/boilerplate") %>
<body>
  <div class="row col-8 offset-2 mt-3">
    <h3>listing details :</h3>
    <div class="card col-12 offset-2">
      <img
        src="<%= listingindetail.image %>"
        class="card-img-top"
        alt="listing image"
      />
      <div class="card-body">
        <p class="card-text mt-2">
          <b><%= listingindetail.title %></b> <br />
          <%= listingindetail.description %><br />
          &#x20B9;<%= listingindetail.price.toLocaleString("en-IN") %><br />
          <%= listingindetail.location %><br />
          <%= listingindetail.country %><br />
        </p>
      </div>
    </div>
  </div>
  <div class="btns d-flex gap-3 offset-2 mt-3">
    <a
      href="/listings/<%= listingindetail._id %>/edit"
      class="btn btn-dark edit"
      >Edit</a
    >

    <form
      method="post"
      action="/listings/<%=listingindetail._id%>?_method=DELETE"
    >
      <button class="btn btn-dark">Delete</button>
    </form>
  </div>
</body>

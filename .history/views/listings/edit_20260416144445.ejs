<% layout("/layouts/boilerplate") %>
<body>
  <h3>Edit your Listing</h3>
  <form method="post" action="/listings/<%= listingindetail._id %>?_method=PUT">
    <div class="mb-3">
      <label for="title" class="form-label">Title</label>
      <input
        name="title"
        value="<%=listingindetail.title%>"
        type="text"
        class="form-control"
      />
    </div>

    <div class="mb-3">
      <label for="description" class="form-label">Description</label>
      <textarea name="description" type="text" class="form-control">
<%= listingindetail.description%> </textarea
      >
    </div>

    <div class="mb-3">
      <label for="image" class="form-label">Image</label>
      <input
        name="image"
        value="<%=listingindetail.image%>"
        class="form-control"
      />
    </div>

    <div class="mb-3">
      <label for="price" class="form-label">Price</label>
      <input
        name="price"
        value="<%=listingindetail.price%>"
        type="number"
        class="form-control"
      />
    </div>

    <div class="mb-3">
      <label for="location" class="form-label">Location</label>
      <input
        name="location"
        value="<%=listingindetail.location%>"
        class="form-control"
      />
    </div>

    <div class="mb-3">
      <label for="country" class="form-label">Country</label>
      <input
        name="country"
        value="<%=listingindetail.country%>"
        class="form-control"
      />
    </div>

    <button class="btn btn-dark edit-btn">Edit</button>
  </form>
</body>

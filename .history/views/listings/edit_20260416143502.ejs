<% layout("/layouts/boilerplate") %>
<body>
  <h3>Edit your Listing</h3>
  <form method="post" action="/listings/<%= listingindetail._id %>?_method=PUT">
    <div class="mb-3">
      <input
        name="title"
        value="<%=listingindetail.title%>"
        type="text"
        class="form-control"
      />
      <label for="title" class="form-label">Title</label>
    </div>

    <div class="mb-3">
      <textarea name="description" type="text">
<%= listingindetail.description%> </textarea
      >
      <label for="title" class="form-label">Title</label>
    </div>

    <br /><br />
    <input name="image" value="<%=listingindetail.image%>" />
    <br /><br />
    <input name="price" value="<%=listingindetail.price%>" type="number" />
    <br /><br />
    <input name="location" value="<%=listingindetail.location%>" />
    <br /><br />
    <input name="country" value="<%=listingindetail.country%>" />
    <br /><br />
    <button>Edit</button>
  </form>
</body>

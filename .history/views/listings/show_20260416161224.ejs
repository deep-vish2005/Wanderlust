<% layout("/layouts/boilerplate") %>
<body>
  <div class="row col-8 offset-2">
    <h3>listing details :</h3>
    <div class="card">
      <img
        src="<%= listingindetail.image %>"
        class="card-img-top"
        alt="listing image"
      />
      <div class="card-body">
        <p class="card-text">
          <%= listingindetail.title %> <%= listingindetail.description %>
          &#x20B9;<%= listingindetail.price.toLocaleString("en-IN") %> <%=
          listingindetail.location %> <%= listingindetail.country %>
        </p>
      </div>
    </div>

    <a href="/listings/<%= listingindetail._id %>/edit">Edit this listing</a>
    <br />
    <form
      method="post"
      action="/listings/<%=listingindetail._id%>?_method=DELETE"
    >
      <br />
      <button>Delete this listing</button>
    </form>
  </div>
</body>

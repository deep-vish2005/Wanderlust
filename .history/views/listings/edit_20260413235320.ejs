<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wanderlust</title>
  </head>
  <body>
    <h3>Edit listing</h3>
    <form>
      <input name="title" value="<%=listing.title%>" type="text" />
      <br /><br />
      <textarea
        name="description"
        value="<%=listing.description%>"
        type="text"
      ></textarea>
      <br /><br />
      <input name="image" value="<%=listing.image%>" />
      <br /><br />
      <input name="price" value="<%=listing.price%>" type="number" />
      <br /><br />
      <input name="location" value="<%=listing.location%>" />
      <br /><br />
      <input name="country" value="<%=listing.country%>" />
      <br /><br />
      <button>Add</button>
    </form>
  </body>
</html>
